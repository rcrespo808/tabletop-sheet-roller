# =========================================================
# PUBLIC / BROWSER-SAFE
# These are exposed to frontend code intentionally
# =========================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# =========================================================
# SERVER-ONLY
# Never expose these to frontend/browser code
# Never prefix these with NEXT_PUBLIC_
# =========================================================

SUPABASE_SECRET_KEY=
# or legacy naming:
SUPABASE_SERVICE_ROLE_KEY=

# =========================================================
# GITHUB ACTIONS / CI-CD
# Stored in GitHub Actions Secrets
# Not in frontend
# =========================================================

SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# =========================================================
# OPTIONAL: ONLY if using GitHub Actions
# to deploy to Vercel manually
# (skip if using Vercel GitHub auto-deploy)
# =========================================================

VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
