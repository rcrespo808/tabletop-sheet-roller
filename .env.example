# =========================================================
# PUBLIC / BROWSER-SAFE
# These are exposed to frontend code intentionally
# =========================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Canonical production app URL (no trailing slash).
# Used for email verification redirects and synced to Supabase in deploy.yml.
# Defaults to https://tabletop-sheet-roller.vercel.app in next.config when unset.
NEXT_PUBLIC_SITE_URL=

# =========================================================
# SERVER-ONLY
# Never expose these to frontend/browser code
# Never prefix these with NEXT_PUBLIC_
# =========================================================

SUPABASE_SECRET_KEY=
# or legacy naming:
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct Postgres URL for the MCP execute_sql tool.
# Use the Supabase pooler/direct database URL and keep it server-only.
SUPABASE_DB_URL=
# or generic naming:
DATABASE_URL=

# Local Dicer content MCP. SUPABASE_PROJECT_ID must match the cloud project
# before write tools apply generated packs.
# In Codex Cloud, these must be environment variables available to the agent
# phase if you expect the MCP to generate or write content there.
SUPABASE_PROJECT_ID=toogirtxlnsbtvmqcqgw
OPENAI_API_KEY=
DICER_CONTENT_MODEL=gpt-5.5
DICER_CONTENT_RUN_DIR=

# =========================================================
# GITHUB ACTIONS / CI-CD SECRET NAMES
# Configure these in GitHub Settings > Secrets and variables > Actions.
# Do not put real CI/CD tokens in local files unless you are debugging locally.
# =========================================================

SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# =========================================================
# Production app deploy secrets used by .github/workflows/deploy.yml.
# These are listed here as names only; configure real values in GitHub Actions.
# =========================================================

VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
